# Mux API token — used ONLY by `npm run sync-mux` to list your video library.
# Never shipped in the app. Copy this file to `.env.local` (gitignored) and fill in.
#
# Create at https://dashboard.mux.com/settings/access-tokens
#   • Permissions: "Mux Video" → Read (Read-only is enough to list assets)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=

# --- Supabase: client (SHIPS in the app bundle) ---
# Safe to expose. Find both at Dashboard → Project Settings → API.
# The publishable key is the "anon"/"publishable" key (starts with sb_publishable_).
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# --- Supabase: server/scripts only — NEVER prefix with EXPO_PUBLIC_ ---
# Secret key == service_role, bypasses RLS. Used by the future admin panel /
# Node scripts. If it ever ships in the app bundle, rotate it immediately.
SUPABASE_SECRET_KEY=

# --- Supabase CLI (for `supabase db push`) ---
SUPABASE_PROJECT_REF=
# SUPABASE_DB_PASSWORD=      # Dashboard → Project Settings → Database
# SUPABASE_ACCESS_TOKEN=     # https://supabase.com/dashboard/account/tokens
