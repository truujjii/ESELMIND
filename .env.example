# Mux API token — used ONLY by `npm run sync-mux` to list your video library.
# Never shipped in the app. Copy this file to `.env.local` (gitignored) and fill in.
#
# Create at https://dashboard.mux.com/settings/access-tokens
#   • Permissions: "Mux Video" → Read (Read-only is enough to list assets)
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
